# Core
PORT=3000
LOG_LEVEL=info

# Storage — required for live API keys
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional licensed quote fallback
FINNHUB_API_KEY=

# Payments — unset renders a labelled demo checkout
