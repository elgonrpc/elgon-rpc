{
  "name": "@elgon/api",
  "version": "0.5.0",
  "description": "Market data API for the Robinhood surface — delayed stock, ETF and crypto quotes, instrument search, sandbox options and prediction feeds",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "engines": { "node": ">=20" },
  "repository": {
    "type": "git",
    "url": "https://github.com/elgonrpc/elgon-rpc.git"
  },
  "homepage": "https://elgonrpc.xyz",
  "keywords": [
    "market-data",
    "stocks",
    "crypto",
    "etf",
    "options",
    "robinhood",
    "quotes",
    "api"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "stripe": "^17.4.0",
    "yahoo-finance2": "^2.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.12.0",
    "prettier": "^3.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
